rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function adminPath(uid) {
      return /databases/$(database)/documents/admins/$(uid);
    }

    function hasAdminRole(data) {
      return data.active == true && data.role in ['owner', 'admin'];
    }

    function isAdmin() {
      return signedIn()
        && exists(adminPath(request.auth.uid))
        && hasAdminRole(get(adminPath(request.auth.uid)).data);
    }

    function isOwner() {
      return signedIn()
        && exists(adminPath(request.auth.uid))
        && get(adminPath(request.auth.uid)).data.active == true
        && get(adminPath(request.auth.uid)).data.role == 'owner';
    }

    match /admins/{uid} {
      allow get: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();
      allow create, update, delete: if isOwner();
    }

    match /settings/{document} {
      allow read, write: if isAdmin();
    }

    match /users/{telegramId} {
      allow read, write: if isAdmin();
    }

    match /activities/{activityId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /errors/{errorId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /analytics/{document=**} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
