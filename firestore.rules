rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function adminDoc() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isActiveAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && adminDoc().data.active == true
        && adminDoc().data.role in ["owner", "admin"];
    }

    function isOwner() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && adminDoc().data.active == true
        && adminDoc().data.role == "owner";
    }

    match /admins/{uid} {
      allow get: if signedIn() && (request.auth.uid == uid || isActiveAdmin());
      allow list: if isActiveAdmin();
      allow create, update, delete: if isOwner();
    }

    match /settings/{document} {
      allow read, write: if isActiveAdmin();
    }

    match /users/{telegramId} {
      allow read, update, delete: if isActiveAdmin();
      allow create: if false;
    }

    match /activities/{activityId} {
      allow read: if isActiveAdmin();
      allow delete: if isActiveAdmin();
      allow create, update: if false;
    }

    match /errors/{errorId} {
      allow read: if isActiveAdmin();
      allow delete: if isActiveAdmin();
      allow create, update: if false;
    }

    match /wrongMatchReports/{reportId} {
      allow read, update, delete: if isActiveAdmin();
      allow create: if false;
    }

    match /userStats/{telegramId} {
      allow read: if isActiveAdmin();
      allow write: if false;
    }

    match /analytics/{document=**} {
      allow read: if isActiveAdmin();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
